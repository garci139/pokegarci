<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="@dimen/search_pokeball_icon_outer_size"
        android:height="@dimen/search_pokeball_icon_outer_size"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
            <stroke
                android:width="@dimen/search_view_stroke_width"
                android:color="@color/black" />
        </shape>
    </item>
    <item
        android:width="@dimen/search_pokeball_icon_inner_size"
        android:height="@dimen/search_pokeball_icon_inner_size"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/pokeball" />
    </item>
</layer-list>
