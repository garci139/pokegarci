<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/pokedexLayout"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminate="true"
        android:theme="@style/Widget.AppCompat.ProgressBar"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/dataErrorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/loadError"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataRetryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/retryLoad"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/dataErrorText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pokedexBox"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/pokedex_list_horizontal_inset"
        android:clipToPadding="false"
        android:clipChildren="true"
        android:elevation="0dp"
        android:fadeScrollbars="true"
        android:paddingBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pokedexHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/pokedex_header_scrim"
        android:clickable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/pokedexTitleAccentLine"
            android:layout_width="0dp"
            android:layout_height="@dimen/pokedex_filters_separator_height"
            android:background="@color/pokedex_title_accent_line"
            app:layout_constraintBottom_toBottomOf="@id/pokedexTitle"
            app:layout_constraintEnd_toEndOf="@id/searchView"
            app:layout_constraintStart_toStartOf="@id/searchView"
            app:layout_constraintTop_toTopOf="@id/pokedexTitle" />

        <TextView
            android:id="@+id/pokedexTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pokedex_title_margin_top"
            android:background="@color/pokedex_header_scrim"
            android:paddingHorizontal="@dimen/pokedex_title_line_padding_horizontal"
            android:text="@string/pokedex_title"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/pokedex_content_horizontal_inset"
            android:layout_marginTop="@dimen/pokedex_title_to_search_gap"
            android:inputType="text"
            style="@style/CustomSearchView"
            android:background="@drawable/search_view_bg"
            android:queryHint="@string/queryHintSearchView"
            app:iconifiedByDefault="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pokedexTitle"
            app:queryBackground="@android:color/transparent"
            app:searchIcon="@drawable/search_pokeball_icon" />

        <include
            android:id="@+id/pokedexFilters"
            layout="@layout/include_pokedex_filters"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/pokedex_content_horizontal_inset"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/searchView" />

        <View
            android:id="@+id/pokedexFiltersSeparator"
            android:layout_width="0dp"
            android:layout_height="@dimen/pokedex_filters_separator_height"
            android:layout_marginTop="@dimen/pokedex_filters_separator_margin_top"
            android:background="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pokedexFilters" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/pokedexListTopAnchor"
        android:layout_width="0dp"
        android:layout_height="@dimen/pokedex_list_below_separator_gap"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pokedexHeader" />

    <View
        android:id="@+id/disableRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <com.garci.pokegarci.ui.pokedex.ExpandedPokemonCardView
        android:id="@+id/expandedPokemonCard"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:layout_marginHorizontal="4dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="16dp"
        app:strokeWidth="5dp"
        app:strokeColor="@color/black"
        app:cardBackgroundColor="@color/expanded_card_bg"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/expandedCardContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="26dp">

            <TextView
                android:id="@+id/expandedPokemonName"
                android:layout_width="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="@string/expandedPokemonName"
                android:layout_gravity="start"
                android:textStyle="bold"
                android:textSize="22sp"
                android:gravity="start" />

            <TextView
                android:id="@+id/expandedPokemonId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="@string/expandedPokemonId"
                android:layout_gravity="end"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:gravity="end" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/expandedPokemonImageBox"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeWidth="5dp"
                app:layout_constraintTop_toBottomOf="@id/expandedPokemonName"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:strokeColor="@color/black"
                app:cardBackgroundColor="@color/white">

                <View
                    android:id="@+id/expandedSubView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/expandedPokemonImage"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:padding="10dp"/>

                    <TextView
                        android:id="@+id/expandedPokemonAbilities"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:paddingStart="10dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="8dp"
                        android:gravity="center"
                        android:text="@string/expandedPokemonAbilities"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:background="@drawable/custom_stats_gridlayout"/>

                    <FrameLayout
                        android:id="@+id/expandedShinyToggleContainer"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/expandedPokemonAbilities"
                        app:layout_constraintBottom_toTopOf="@id/expandedPokemonHeight">

                        <ImageButton
                            android:id="@+id/expandedShinyToggleButton"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/shiny_toggle_background"
                            android:contentDescription="@string/expandedPokemonShinyToggle"
                            android:padding="3dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_shiny_toggle"
                            app:tint="@color/shiny_toggle_icon_tint" />

                        <ImageView
                            android:id="@+id/expandedShinyToggleDisabledStrike"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:importantForAccessibility="no"
                            android:src="@drawable/shiny_toggle_disabled_strike"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/expandedPokemonHeight"
                        android:layout_width="wrap_content"
                        android:paddingEnd="8dp"
                        android:paddingBottom="2dp"
                        android:paddingStart="10dp"
                        android:layout_height="26dp"
                        android:gravity="center"
                        android:text="@string/expandedPokemonHeight"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:background="@drawable/custom_stats_gridlayout"/>

                    <TextView
                        android:id="@+id/expandedPokemonWeight"
                        android:layout_width="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingBottom="2dp"
                        android:paddingEnd="10dp"
                        android:layout_height="26dp"
                        android:gravity="center"
                        android:text="@string/expandedPokemonWeight"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:background="@drawable/custom_stats_gridlayout"/>

                    <LinearLayout
                        android:id="@+id/expandedPokemonTypes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_margin="12dp">

                        <ImageView
                            android:id="@+id/expandedFirstTypeIcon"
                            android:background="@drawable/image_border_bg"
                            android:padding="1dp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="4dp"/>

                        <ImageView
                            android:id="@+id/expandedSecondTypeIcon"
                            android:background="@drawable/image_border_bg"
                            android:padding="1dp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"/>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/expandedDescriptionTitle"
                app:layout_constraintTop_toBottomOf="@id/expandedPokemonImageBox"
                app:layout_constraintStart_toStartOf="parent"
                android:text="@string/expandedPokemonDescriptionTitle"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:gravity="start"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/expandedPokemonDescription"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/expandedPokemonDescription"
                android:textIsSelectable="false"
                android:contextClickable="false"
                app:layout_constraintTop_toBottomOf="@id/expandedDescriptionTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:textStyle="italic"
                android:justificationMode="inter_word"
                android:layout_marginTop="4dp"
                android:textColor="@color/black"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/expandedStatsTitle"
                app:layout_constraintTop_toBottomOf="@id/expandedPokemonDescription"
                app:layout_constraintStart_toStartOf="parent"
                android:text="@string/expandedStatsTitle"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:gravity="start"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:id="@+id/statsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/expandedStatsTitle"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/expandedPokemonDescription"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:stretchColumns="*"
                    android:padding="0.6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@color/black">

                    <TableRow>
                        <TextView
                            android:text="@string/HP"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonHP"
                            android:text="@string/HP_API"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false" />

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/Attack"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonAttack"
                            android:text="@string/Attack_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/Defense"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonDefense"
                            android:text="@string/Defense_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                </TableLayout>

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toBottomOf="@id/expandedPokemonDescription"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:stretchColumns="*"
                    android:padding="0.6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@color/black"
                    android:textAlignment="center">

                    <TableRow>

                        <TextView
                            android:text="@string/Speed"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpeed"
                            android:gravity="center"
                            android:text="@string/Speed_API"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>
                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/SpAttack"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpAttack"
                            android:text="@string/SpAttack_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/SpDefense"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/light_grey"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpDefense"
                            android:text="@string/SpDefense_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:textColor="@color/black"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                </TableLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandedCardNavBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/expanded_card_nav_bar_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsBox">

                <ImageButton
                    android:id="@+id/expandedCardPrevButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/pokedex_expanded_prev"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_pokedex_nav_arrow_left"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <View
                    android:id="@+id/expandedCardNavDividerStart"
                    android:layout_width="@dimen/expanded_card_nav_divider_width"
                    android:layout_height="28dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/black"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/closeCardButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minHeight="40dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="@string/closeExpandedCard"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/expandedCardNavDividerEnd"
                    android:layout_width="@dimen/expanded_card_nav_divider_width"
                    android:layout_height="28dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/black"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <ImageButton
                    android:id="@+id/expandedCardNextButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/pokedex_expanded_next"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_pokedex_nav_arrow_right"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.garci.pokegarci.ui.pokedex.ExpandedPokemonCardView>

</androidx.constraintlayout.widget.ConstraintLayout>