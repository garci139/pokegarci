<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/pokedexLayout"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminate="true"
        android:theme="@style/Widget.AppCompat.ProgressBar"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/dataErrorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/loadError"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataRetryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/retryLoad"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/dataErrorText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pokedexBox"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/pokedex_content_horizontal_inset"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:elevation="0dp"
        android:fadeScrollbars="true"
        android:paddingBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pokedexHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/appTopBarInclude"
            layout="@layout/include_app_top_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/pokedexToolbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/pokedex_header_scrim"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingTop="@dimen/pokedex_toolbar_padding_top"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appTopBarInclude">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/pokedex_content_horizontal_inset"
                android:inputType="text"
                style="@style/CustomSearchView"
                android:background="@drawable/search_view_bg"
                android:queryHint="@string/queryHintSearchView"
                app:iconifiedByDefault="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:queryBackground="@android:color/transparent"
                app:searchIcon="@drawable/search_emerald_triangle_icon" />

            <include
                android:id="@+id/pokedexFilters"
                layout="@layout/include_pokedex_filters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/pokedex_content_horizontal_inset"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/searchView" />

            <View
                android:id="@+id/pokedexFiltersSeparator"
                android:layout_width="0dp"
                android:layout_height="@dimen/pokedex_filters_separator_height"
                android:layout_marginTop="@dimen/pokedex_filters_separator_margin_top"
                android:background="@color/black"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pokedexFilters" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/pokedexListTopAnchor"
        android:layout_width="0dp"
        android:layout_height="@dimen/pokedex_list_below_separator_gap"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pokedexHeader" />

    <View
        android:id="@+id/disableRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <com.garci.pokegarci.ui.pokedex.ExpandedPokemonCardView
        android:id="@+id/expandedPokemonCard"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:layout_marginHorizontal="4dp"
        android:background="@drawable/emerald_gba_window_bg"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        tools:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/expandedCardContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/emerald_gba_expanded_content_padding">

            <TextView
                android:id="@+id/expandedPokemonName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/expandedPokemonName"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/expandedPokemonId"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/expandedPokemonId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:includeFontPadding="false"
                android:text="@string/expandedPokemonId"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/expandedPokemonName"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/expandedHeaderBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="expandedPokemonName,expandedPokemonId" />

            <FrameLayout
                android:id="@+id/expandedPokemonImageBox"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/emerald_gba_window_bg"
                android:clipChildren="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/expandedHeaderBottom">

                <View
                    android:id="@+id/expandedSubView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/emerald_gba_window_fill_inset"
                    android:clickable="true"
                    android:focusable="true" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/emerald_gba_window_fill_inset"
                    android:clipChildren="false"
                    android:padding="@dimen/pokedex_card_inner_padding">

                    <ImageView
                        android:id="@+id/expandedPokemonImage"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:padding="10dp"/>

                    <TextView
                        android:id="@+id/expandedPokemonAbilities"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="26dp"
                        android:background="@drawable/emerald_gba_field_bg"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="@string/expandedPokemonAbilities"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <FrameLayout
                        android:id="@+id/expandedShinyToggleContainer"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/expandedPokemonAbilities"
                        app:layout_constraintBottom_toTopOf="@id/expandedPokemonHeight">

                        <ImageButton
                            android:id="@+id/expandedShinyToggleButton"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/shiny_toggle_background"
                            android:contentDescription="@string/expandedPokemonShinyToggle"
                            android:padding="3dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_shiny_toggle"
                            app:tint="@color/shiny_toggle_icon_tint" />

                        <ImageView
                            android:id="@+id/expandedShinyToggleDisabledStrike"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:importantForAccessibility="no"
                            android:src="@drawable/shiny_toggle_disabled_strike"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/expandedPokemonHeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="26dp"
                        android:background="@drawable/emerald_gba_field_bg"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="@string/expandedPokemonHeight"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/expandedPokemonWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="26dp"
                        android:background="@drawable/emerald_gba_field_bg"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="@string/expandedPokemonWeight"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <LinearLayout
                        android:id="@+id/expandedPokemonTypes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/expandedFirstTypeIcon"
                            android:background="@drawable/image_border_bg"
                            android:padding="1dp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="4dp"/>

                        <ImageView
                            android:id="@+id/expandedSecondTypeIcon"
                            android:background="@drawable/image_border_bg"
                            android:padding="1dp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"/>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/expandedDescriptionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="start"
                android:text="@string/expandedPokemonDescriptionTitle"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/expandedPokemonImageBox" />

            <FrameLayout
                android:id="@+id/expandedDescriptionBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/emerald_gba_window_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/expandedDescriptionTitle">

                <TextView
                    android:id="@+id/expandedPokemonDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contextClickable="false"
                    android:justificationMode="inter_word"
                    android:minHeight="60dp"
                    android:paddingVertical="@dimen/pokedex_card_inner_padding_vertical"
                    android:paddingHorizontal="@dimen/pokedex_card_inner_padding_horizontal"
                    android:text="@string/expandedPokemonDescription"
                    android:textColor="@color/black"
                    android:textIsSelectable="false"
                    android:textSize="16sp"
                    android:textStyle="italic" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/expandedStatsTitle"
                app:layout_constraintTop_toBottomOf="@id/expandedDescriptionBox"
                app:layout_constraintStart_toStartOf="parent"
                android:text="@string/expandedStatsTitle"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:gravity="start"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:id="@+id/statsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/expandedStatsTitle"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/expandedPokemonDescription"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:stretchColumns="*"
                    android:padding="0.6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@color/emerald_gba_border_outer">

                    <TableRow>
                        <TextView
                            android:text="@string/HP"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonHP"
                            android:text="@string/HP_API"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false" />

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/Attack"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonAttack"
                            android:text="@string/Attack_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/Defense"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonDefense"
                            android:text="@string/Defense_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                </TableLayout>

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toBottomOf="@id/expandedPokemonDescription"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:stretchColumns="*"
                    android:padding="0.6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@color/emerald_gba_border_outer"
                    android:textAlignment="center">

                    <TableRow>

                        <TextView
                            android:text="@string/Speed"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpeed"
                            android:gravity="center"
                            android:text="@string/Speed_API"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>
                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/SpAttack"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpAttack"
                            android:text="@string/SpAttack_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:textColor="@color/black"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                    <TableRow>

                        <TextView
                            android:text="@string/SpDefense"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_stat_label_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="0.7"
                            android:textIsSelectable="false" />

                        <TextView
                            android:id="@+id/expandedPokemonSpDefense"
                            android:text="@string/SpDefense_API"
                            android:gravity="center"
                            android:layout_weight="0.3"
                            android:textColor="@color/black"
                            android:layout_margin="0.6dp"
                            android:padding="2dp"
                            android:background="@drawable/emerald_gba_field_bg"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:textIsSelectable="false"/>

                    </TableRow>

                </TableLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandedCardNavBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/expanded_card_nav_bar_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsBox">

                <ImageButton
                    android:id="@+id/expandedCardPrevButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/pokedex_expanded_prev"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_pokedex_nav_arrow_left"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <View
                    android:id="@+id/expandedCardNavDividerStart"
                    android:layout_width="@dimen/expanded_card_nav_divider_width"
                    android:layout_height="28dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/black"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/closeCardButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minHeight="40dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="@string/closeExpandedCard"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/expandedCardNavDividerEnd"
                    android:layout_width="@dimen/expanded_card_nav_divider_width"
                    android:layout_height="28dp"
                    android:layout_marginVertical="4dp"
